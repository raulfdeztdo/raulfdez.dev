---
import { languages } from "../i18n/ui";
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
---

<div class="relative ml-1 mr-1">
  <button
    id="language-toggle-btn"
    class="appearance-none border-none flex hover:scale-125 transition text-current"
  >
    <span class="sr-only">Cambiar idioma</span>
    <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"
      ></path>
    </svg>
  </button>
  <div
    id="languages-menu"
    class="absolute hidden scale-80 top-8 right-0 text-sm p-1 min-w-[6rem] rounded-md border border-gray-100 bg-white/90 dark:bg-gray-900/90 dark:border-gray-500/20 shadow-[0_3px_10px_rgb(0,0,0,0.2)] backdrop-blur-md"
  >
    <ul>
      {
        Object.entries(languages).map(([langCode, langName]) => (
          <li class="language-option px-2 py-1.5 cursor-pointer hover:bg-neutral-400/40 dark:hover:bg-gray-500/50 rounded-sm">
            <a
              href={langCode === "es" ? "/" : `/${langCode}/`}
              class={`block w-full ${lang === langCode ? "font-semibold text-blue-500" : ""}`}
            >
              {langName}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</div>

<style>
  #languages-menu.open {
    display: inline;
    animation: scale-up-center 0.15s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }

  @keyframes scale-up-center {
    from {
      transform: scale(0.8);
      opacity: 0;
    }

    to {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const languageToggleBtn = document.querySelector("#language-toggle-btn");
    const languagesMenu = document.querySelector("#languages-menu");

    const handleToggleClick = () => {
      languagesMenu?.classList.toggle("open");
    };

    const handleClickOutside = (event: MouseEvent) => {
      if (
        !languageToggleBtn?.contains(event.target as Node) &&
        !languagesMenu?.contains(event.target as Node)
      ) {
        languagesMenu?.classList.remove("open");
      }
    };

    languageToggleBtn?.addEventListener("click", handleToggleClick);
    document.addEventListener("click", handleClickOutside);

    // Cleanup
    return () => {
      languageToggleBtn?.removeEventListener("click", handleToggleClick);
      document.removeEventListener("click", handleClickOutside);
    };
  });
</script>
